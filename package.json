{
  "name": "@npmc_5/codex-claw",
  "version": "0.1.2",
  "description": "Telegram-native Codex agent harness for Bun",
  "license": "MIT",
  "private": false,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "engines": {
    "bun": ">=1.3.5"
  },
  "bin": {
    "codex-claw": "bin/codex-claw"
  },
  "keywords": [
    "telegram",
    "bot",
    "codex",
    "openai",
    "grammy",
    "bun",
    "agent"
  ],
  "files": [
    "bin",
    "src",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinion05/codex-claw.git"
  },
  "homepage": "https://github.com/pinion05/codex-claw#readme",
  "bugs": {
    "url": "https://github.com/pinion05/codex-claw/issues"
  },
  "scripts": {
    "check": "bun test && bun run typecheck",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "pack:dry-run": "bun pm pack --dry-run",
    "publish:dry-run": "bun publish --dry-run --access public",
    "publish:npm": "bun publish --access public",
    "release:patch": "bun pm version patch",
    "release:minor": "bun pm version minor",
    "release:major": "bun pm version major",
    "prepublishOnly": "bun run check",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.111.0",
    "grammy": "1.41.1"
  }
}
